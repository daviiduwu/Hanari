{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hanari.dev/schemas/reasoning-trace.schema.json",
  "title": "ReasoningTrace",
  "type": "object",
  "required": ["traceId", "sentence", "contextSnapshot", "steps", "decisions", "pedagogy"],
  "properties": {
    "traceId": { "type": "string" },
    "sentence": { "type": "string" },
    "contextSnapshot": {
      "type": "object",
      "required": ["tokens", "clause"],
      "properties": {
        "tokens": { "type": "array", "items": { "type": "object" } },
        "clause": { "type": ["object", "null"] },
        "morphology": { "type": "array", "items": { "type": "object" } },
        "metadata": {
          "type": "object",
          "properties": {
            "sentenceType": { "enum": ["declarative", "question", "imperative", "fragment"] },
            "registerGuess": { "enum": ["neutral", "informal", "spoken"] },
            "dialect": { "enum": ["en-US", "en-GB", "global"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stepIndex", "phase", "inputRefs", "operation", "result", "details"],
        "properties": {
          "stepIndex": { "type": "integer", "minimum": 0 },
          "phase": { "enum": ["precondition", "detection", "conflict-resolution", "explanation"] },
          "ruleId": { "type": "string" },
          "inputRefs": { "type": "array", "items": { "type": "string" } },
          "operation": { "type": "string" },
          "result": { "enum": ["pass", "fail", "skip"] },
          "details": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "decisions": {
      "type": "object",
      "required": ["triggeredRules", "suppressedRules", "finalFindings"],
      "properties": {
        "triggeredRules": { "type": "array", "items": { "type": "string" } },
        "suppressedRules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ruleId", "reason"],
            "properties": {
              "ruleId": { "type": "string" },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "finalFindings": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": false
    },
    "pedagogy": {
      "type": "object",
      "required": ["explanationPlan"],
      "properties": {
        "learnerLevel": { "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
        "explanationPlan": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
